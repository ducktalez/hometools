# Copy this file to .env and fill in your values.
# Never commit .env to version control!

TMDB_API_KEY=your_tmdb_api_key_here
HOMETOOLS_DELETE_DIR=C:/Users/YourName/Music/DELETE_ME
HOMETOOLS_AUDIO_LIBRARY_DIR=C:/Media/audio-library
HOMETOOLS_AUDIO_NAS_DIR=Z:/Music
HOMETOOLS_VIDEO_LIBRARY_DIR=C:/Media/video-library
HOMETOOLS_VIDEO_NAS_DIR=Z:/Video
HOMETOOLS_STREAM_HOST=127.0.0.1
HOMETOOLS_STREAM_PORT=8010
HOMETOOLS_AUDIO_PORT=8010
HOMETOOLS_VIDEO_PORT=8011
HOMETOOLS_STREAM_INDEX_CACHE_TTL=900
HOMETOOLS_STREAM_SAFE_MODE=false

# ─────────────────────────────────────────────────────────────────────────
# Audit Log Directory
# ─────────────────────────────────────────────────────────────────────────
#
# Permanent, append-only audit log for rating writes, tag edits, and renames.
# Lives OUTSIDE the disposable shadow cache so "make clean" cannot destroy it.
# Default: .hometools-audit/ in the repo root.
#
# HOMETOOLS_AUDIT_DIR=C:/Media/.hometools-audit

# ─────────────────────────────────────────────────────────────────────────
# Video PWA Display Mode (iOS trade-off)
# ─────────────────────────────────────────────────────────────────────────
#
# "standalone" (default previously)
#   ✅ Installed as native Home Screen app
#   ✅ Fullscreen button visible
#   ❌ Background playback blocked
#   ❌ PiP blocked by iOS
#
# "minimal-ui" (current default)
#   ✅ Background audio playback works
#   ✅ PiP (miniplayer) works
#   ✅ Fullscreen APIs work
#   ❌ "Add to Home Screen" creates web link, not PWA
#
# See INSTRUCTIONS_background_video_playback.md for details.
#
HOMETOOLS_VIDEO_PWA_DISPLAY=minimal-ui

# ─────────────────────────────────────────────────────────────────────────
# Player Bar Style
# ─────────────────────────────────────────────────────────────────────────
#
# "classic"  — single-row player bar (default)
# "waveform" — two-row with audio waveform / video thumbnails
#
HOMETOOLS_PLAYER_BAR_STYLE=classic


# ─────────────────────────────────────────────────────────────────────────
# Recently Played — Video Start Screen
# ─────────────────────────────────────────────────────────────────────────
#
# Only the video server shows a "Zuletzt gespielt" (recently played) section
# on the start screen. The audio server never shows this section; audiobooks
# resume from the last position automatically via the progress API.
#
# HOMETOOLS_RECENT_VIDEO_LIMIT   — max episodes shown (default 3)
# HOMETOOLS_RECENT_MAX_AGE_DAYS  — max age in days; older items are hidden (default 14)
# HOMETOOLS_RECENT_MAX_PER_SERIES — max episodes per series kept (default 1,
#                                   only the most-recently-seen episode is shown)
#
HOMETOOLS_RECENT_VIDEO_LIMIT=3
HOMETOOLS_RECENT_MAX_AGE_DAYS=14
HOMETOOLS_RECENT_MAX_PER_SERIES=1


# ─────────────────────────────────────────────────────────────────────────
# Channel (TV) Server — Live Stream
# ─────────────────────────────────────────────────────────────────────────
#
# The channel server produces a continuous HLS live stream, mixing
# scheduled series episodes with filler content between them.
# Uses ffmpeg for on-the-fly transcoding to HLS segments.
#
# HOMETOOLS_CHANNEL_PORT       — server port (default: video port + 1 = 8012)
# HOMETOOLS_CHANNEL_SCHEDULE   — path to schedule YAML (default: channel_schedule.yaml in repo root)
# HOMETOOLS_CHANNEL_FILLER_DIR — directory with filler clips/music (default: <video-library>/filler/)
# HOMETOOLS_CHANNEL_ENCODER    — ffmpeg video encoder (default: libx264; alternatives: h264_nvenc, h264_qsv)
#
HOMETOOLS_CHANNEL_PORT=8012
# HOMETOOLS_CHANNEL_SCHEDULE=channel_schedule.yaml
# HOMETOOLS_CHANNEL_FILLER_DIR=C:/Media/video-library/filler
# HOMETOOLS_CHANNEL_ENCODER=libx264


# ─────────────────────────────────────────────────────────────────────────
# Playlist Behaviour
# ─────────────────────────────────────────────────────────────────────────
#
# HOMETOOLS_PLAYLIST_INSERT_POSITION — where new items are inserted:
#   "bottom" (default, Spotify-style) — appended at the end
#   "top" — inserted at the beginning (newest first)
#
# HOMETOOLS_PLAYLIST_SYNC_INTERVAL — polling interval in seconds for
#   cross-device playlist sync (default: 30, minimum: 5)
#
# HOMETOOLS_PLAYLIST_INSERT_POSITION=bottom
# HOMETOOLS_PLAYLIST_SYNC_INTERVAL=30

# ─────────────────────────────────────────────────────────────────────────
# Rating Threshold — Hide Low-Rated Tracks
# ─────────────────────────────────────────────────────────────────────────
#
# Tracks that have been rated at or below this star threshold are hidden
# from the UI.  Unrated tracks (no rating) are always shown.
# Value range: 0–5.  Default 0 = show all tracks.
#
# Example: HOMETOOLS_MIN_RATING=2 hides all 1★ and 2★ tracks.
#
# HOMETOOLS_MIN_RATING=0

# ─────────────────────────────────────────────────────────────────────────
# Crossfade — Seamless Song Transitions (Audio only)
# ─────────────────────────────────────────────────────────────────────────
#
# Duration in seconds for crossfading between songs.
# 0 = disabled (hard cut, default).  Typical: 3–5 seconds.  Max: 12.
# Only applies to the audio server; video always uses hard cuts.
#
# HOMETOOLS_CROSSFADE_DURATION=0



