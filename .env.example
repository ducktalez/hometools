# Copy this file to .env and fill in your values.
# Never commit .env to version control!

TMDB_API_KEY=your_tmdb_api_key_here
HOMETOOLS_DELETE_DIR=C:/Users/YourName/Music/DELETE_ME
HOMETOOLS_AUDIO_LIBRARY_DIR=C:/Media/audio-library
HOMETOOLS_AUDIO_NAS_DIR=Z:/Music
HOMETOOLS_VIDEO_LIBRARY_DIR=C:/Media/video-library
HOMETOOLS_VIDEO_NAS_DIR=Z:/Video
HOMETOOLS_STREAM_HOST=127.0.0.1
HOMETOOLS_STREAM_PORT=8010
HOMETOOLS_AUDIO_PORT=8010
HOMETOOLS_VIDEO_PORT=8011
HOMETOOLS_STREAM_INDEX_CACHE_TTL=900
HOMETOOLS_STREAM_SAFE_MODE=false

# ─────────────────────────────────────────────────────────────────────────
# Video PWA Display Mode (iOS trade-off)
# ─────────────────────────────────────────────────────────────────────────
#
# "standalone" (default previously)
#   ✅ Installed as native Home Screen app
#   ✅ Fullscreen button visible
#   ❌ Background playback blocked
#   ❌ PiP blocked by iOS
#
# "minimal-ui" (current default)
#   ✅ Background audio playback works
#   ✅ PiP (miniplayer) works
#   ✅ Fullscreen APIs work
#   ❌ "Add to Home Screen" creates web link, not PWA
#
# See INSTRUCTIONS_background_video_playback.md for details.
#
HOMETOOLS_VIDEO_PWA_DISPLAY=minimal-ui

# ─────────────────────────────────────────────────────────────────────────
# Player Bar Style
# ─────────────────────────────────────────────────────────────────────────
#
# "classic"  — single-row player bar (default)
# "waveform" — two-row with audio waveform / video thumbnails
#
HOMETOOLS_PLAYER_BAR_STYLE=classic


