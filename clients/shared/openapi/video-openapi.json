    "/api/video/continue": {
      "get": {
        "summary": "Video Continue Watching",
        "description": "Return unfinished, recently-played videos for a \"Continue Watching\" row.\n\nJoins the playback-progress store with the current catalog so each\nentry carries full item metadata (title, artist, thumbnail, stream URL,\nintro markers) plus the resume position. Built for the native TV client\n(10-foot UI), but generic enough for any consumer. Never 500s — returns\n``{\"items\": []}`` when the catalog isn't ready or on any error.",
        "operationId": "video_continue_watching_api_video_continue_get",
        "parameters": [
          {
            "name": "limit",
