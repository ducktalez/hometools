# ────────────────────────────────────────────────────────────────────
# hometools — Docker-Compose .env für die Synology NAS (Syn723)
#
# Auf der NAS in den Projektordner kopieren und in ".env" umbenennen:
#   cp docker/.env.synology.example .env
# (Das Deploy-Skript scripts/deploy-synology.sh macht das automatisch.)
#
# ACHTUNG: Dies ist NICHT dasselbe Schema wie die lokale Dev-.env
# (HOMETOOLS_*_LIBRARY_DIR). docker-compose.yml interpoliert die Variablen
# unten beim Container-Build.
# ────────────────────────────────────────────────────────────────────

# ── User-/Gruppen-ID des DSM-Users mit Leserechten auf die Medien ─────
# >>> PRÜFEN <<< — auf der NAS per SSH:  id <dein-dsm-user>
# (typischer Synology-Wert 1026 / 100). Falsche Werte => "Permission denied".
PUID=1026
PGID=100

# ── Bibliothekspfade auf der DISKSTATION (read-only gemountet) ────────
# Video-Default aus deiner Dev-Konfig abgeleitet (\\Syn723\Serien → /volume1/Serien).
# >>> PRÜFEN <<< ob der Volume-Pfad stimmt (DSM → File Station zeigt den realen Pfad).
VIDEO_LIBRARY_PATH=/volume1/Serien

# Audio ist OPTIONAL und läuft NICHT per Default (Compose-Profil "audio").
# Nur relevant, wenn du den Audio-Server mit  ENABLE_AUDIO=1  bzw.
#   docker compose --profile audio up -d --build
# startest — dann hier eine existierende Freigabe eintragen:
AUDIO_LIBRARY_PATH=/volume1/music

# ── Ports im LAN ──────────────────────────────────────────────────────
# Danach erreichbar: http://192.168.178.87:8010 (Audio) / :8011 (Video)
AUDIO_PORT=8010
VIDEO_PORT=8011
CHANNEL_PORT=8012

# ── Optionale Streaming-Tweaks ────────────────────────────────────────
HOMETOOLS_DEFAULT_LANGUAGE=de
HOMETOOLS_VIDEO_PWA_DISPLAY=minimal-ui
HOMETOOLS_MIN_RATING=0

# Pre-Transcode beim Start: NICHT als Default empfohlen — transkodiert die
# GANZE Bibliothek und kann den Cache-Datenträger füllen. Nur einschalten,
# wenn der TV-Browser .avi/.mkv partout nicht abspielt. Ohne diese Option
# wird on-demand beim Abspielen transkodiert.
# HOMETOOLS_PRETRANSCODE=true

