# ────────────────────────────────────────────────────────────────────
# Docker-Compose-Konfiguration für hometools
# Kopiere diese Datei nach .env im Repo-Root: cp docker/.env.example .env
# ────────────────────────────────────────────────────────────────────

# UID/GID des Users, dem die Mediendateien gehören (auf Synology: DSM → User → ID).
# Standard 1000/1000 passt für die meisten Linux-Hosts und Raspberry Pi.
PUID=1000
PGID=1000

# ── Bibliothekspfade auf dem HOST ─────────────────────────────────
# Werden read-only in den Container gemountet.
# Synology-Beispiel (Audio + Video direkt auf der Diskstation):
#   AUDIO_LIBRARY_PATH=/volume1/music
#   VIDEO_LIBRARY_PATH=/volume1/video
# Linux/Mac-Beispiel:
#   AUDIO_LIBRARY_PATH=/home/me/Music
#   VIDEO_LIBRARY_PATH=/mnt/nas/video
# Windows-Beispiel (Docker Desktop):
#   AUDIO_LIBRARY_PATH=C:\Users\Simon\Music
#   VIDEO_LIBRARY_PATH=Z:\Video
AUDIO_LIBRARY_PATH=/path/to/your/audio
VIDEO_LIBRARY_PATH=/path/to/your/video

# ── Ports auf dem HOST ────────────────────────────────────────────
AUDIO_PORT=8010
VIDEO_PORT=8011
CHANNEL_PORT=8012

# ── Optional: Streaming-Tweaks (durchgereicht an die Server) ──────
HOMETOOLS_DEFAULT_LANGUAGE=de
HOMETOOLS_VIDEO_PWA_DISPLAY=minimal-ui
HOMETOOLS_MIN_RATING=0

